{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "discovery_intent.schema.json",
  "title": "DiscoveryIntent",
  "description": "Structured search intent produced by the Intent Translator. Nested in DiscoveryTaskSpec as payload.discovery_intent inside input.json. Aligned with packages/contracts/agents/discovery_intent.py::DiscoveryIntent. If this schema conflicts with the Pydantic model, the Pydantic model wins.",
  "type": "object",
  "required": [
    "translator_version",
    "raw_user_request",
    "interpreted_goal",
    "search_mode",
    "target_role_families",
    "excluded_role_families",
    "hard_constraints",
    "profile_role",
    "expansion_scope"
  ],
  "additionalProperties": false,
  "properties": {
    "translator_version": {
      "type": "string",
      "description": "Version tag for the translator prompt/logic."
    },
    "raw_user_request": {
      "type": "string",
      "description": "Original user instruction, preserved verbatim for audit."
    },
    "interpreted_goal": {
      "type": "string",
      "description": "One-sentence summary of what the agent should achieve this run."
    },
    "search_mode": {
      "type": "string",
      "enum": ["direct", "exploratory", "profile_guided"]
    },
    "target_role_families": {
      "type": "array",
      "items": { "$ref": "#/definitions/role_family" },
      "description": "Role directions to search. Non-empty for a non-blocking result."
    },
    "excluded_role_families": {
      "type": "array",
      "items": { "$ref": "#/definitions/role_family" },
      "description": "Role directions to avoid. Exclusions must have source=user_explicit."
    },
    "hard_constraints": {
      "$ref": "#/definitions/hard_constraints"
    },
    "soft_preferences": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Per-run preferences from user input; not inferred from profile."
    },
    "profile_role": {
      "type": "string",
      "enum": ["none", "supporting", "primary"]
    },
    "capability_signals": {
      "type": "array",
      "items": { "$ref": "#/definitions/capability_signal" }
    },
    "expansion_scope": {
      "type": "string",
      "enum": ["narrow", "standard", "wide"]
    },
    "ambiguity_flags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Unresolved ambiguities preserved for UI and diagnostics."
    }
  },
  "definitions": {
    "role_family": {
      "type": "object",
      "required": ["name", "rationale", "source"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "rationale": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["user_explicit", "profile_signal", "inferred_adjacent"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "high"
        }
      }
    },
    "capability_signal": {
      "type": "object",
      "required": ["cluster_name", "description", "adjacent_role_targets", "signal_type"],
      "additionalProperties": false,
      "properties": {
        "cluster_name": { "type": "string" },
        "description": { "type": "string" },
        "adjacent_role_targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signal_type": {
          "type": "string",
          "enum": ["domain", "technical", "business"]
        }
      }
    },
    "hard_constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "location": { "type": ["string", "null"] },
        "seniority": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude_role_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_include_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "work_arrangement": {
          "type": ["string", "null"],
          "enum": ["hybrid", "remote", "onsite", "any", null]
        },
        "visa_note": { "type": ["string", "null"] },
        "compensation_range": { "type": ["string", "null"] }
      }
    }
  }
}
