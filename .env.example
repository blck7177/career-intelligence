# === LLM ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-opus-4-5

# === Database ===
DATABASE_URL=postgresql://career:career@localhost:5432/career_openclaw

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API ===
ENV=development
DEV_MODE=1
SESSION_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Worker ===
# Comma-separated task types this worker handles (empty = all)
WORKER_TASK_TYPES=

# === OpenClaw ===
# Runtime paths (used inside Docker containers — do not change unless you know what you are doing)
OPENCLAW_CONFIG_PATH=/app/agent/openclaw/config/openclaw.json
OPENCLAW_STATE_DIR=/openclaw/state
OPENCLAW_WORKSPACE_DIR=/openclaw/workspace
# Gateway auth token — required when gateway.bind=lan (OpenClaw 2026.6+).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
# The entrypoint will auto-generate one if unset, but setting it here makes it
# stable across container restarts without rebuilding.
OPENCLAW_GATEWAY_TOKEN=

# === Storage ===
AGENT_ARTIFACTS_DIR=/app/data/agent_artifacts

# === Auth ===
# Invite codes for MVP (comma-separated)
INVITE_CODES=

# === Workspace ===
CATALOG_WORKSPACE_ID=dev_default
