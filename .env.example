# === LLM ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-opus-4-5

# === Database ===
DATABASE_URL=postgresql://career:career@localhost:5432/career_openclaw

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API ===
ENV=development
DEV_MODE=1
SESSION_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Worker ===
# Comma-separated task types this worker handles (empty = all)
WORKER_TASK_TYPES=

# === OpenClaw ===
OPENCLAW_CONFIG_PATH=/app/agent/openclaw/config/openclaw.json
OPENCLAW_STATE_DIR=/openclaw/state
OPENCLAW_WORKSPACE_DIR=/openclaw/workspace

# === Storage ===
AGENT_ARTIFACTS_DIR=/app/data/agent_artifacts

# === Auth ===
# Invite codes for MVP (comma-separated)
INVITE_CODES=

# === Workspace ===
CATALOG_WORKSPACE_ID=dev_default
