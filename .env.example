# === LLM ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-opus-4-5

# === Database ===
DATABASE_URL=postgresql://career:career@localhost:5432/career_openclaw

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API ===
ENV=development
DEV_MODE=1
SESSION_TTL_DAYS=30
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Worker ===
# Comma-separated task types this worker handles (empty = all)
WORKER_TASK_TYPES=

# === OpenClaw ===
# Runtime paths (used inside Docker containers — do not change unless you know what you are doing)
OPENCLAW_CONFIG_PATH=/openclaw/config/openclaw.json
OPENCLAW_STATE_DIR=/openclaw/state
OPENCLAW_WORKSPACE_DIR=/openclaw/workspace
# Gateway auth token — required when gateway.bind=lan (OpenClaw 2026.6+).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
# The entrypoint will auto-generate one if unset, but setting it here makes it
# stable across container restarts without rebuilding.
OPENCLAW_GATEWAY_TOKEN=

# === Storage ===
AGENT_ARTIFACTS_DIR=/app/data/agent_artifacts

# === Auth (Clerk) ===
# Backend — JWKS endpoint for JWT verification (FastAPI)
# Get from: Clerk Dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
# Optional: restrict accepted audience claim
CLERK_AUDIENCE=

# Frontend — Next.js Clerk keys
# Get from: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# === Tool Ledger ===
# HMAC signing key for platform wrapper events. Min 32 bytes.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
TOOL_LEDGER_SIGNING_KEY=

# === Search ===
# Tavily API key for web_search tool (https://tavily.com)
TAVILY_API_KEY=

# === Workspace ===
CATALOG_WORKSPACE_ID=dev_default
