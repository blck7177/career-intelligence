# =============================================================================
# Production environment — copy to .env.prod and fill in real values
# NEVER commit .env.prod to git
# =============================================================================

# --- Domain (used by Caddy for automatic HTTPS) ---
DOMAIN=yourdomain.com

# --- RDS Postgres ---
# Docker .env files don't support self-referencing variables.
# Write the full DATABASE_URL directly. Keep RDS_* for the backup sidecar.
RDS_HOST=your-rds-instance.xxxx.us-east-1.rds.amazonaws.com
RDS_USER=career
RDS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RDS_DATABASE=career_openclaw
DATABASE_URL=postgresql://career:CHANGE_ME_STRONG_PASSWORD@your-rds-instance.xxxx.us-east-1.rds.amazonaws.com:5432/career_openclaw

# --- Redis (internal Docker service) ---
REDIS_URL=redis://redis:6379/0

# --- Clerk auth ---
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx

# --- CORS (must match your production domain) ---
CORS_ORIGINS=https://yourdomain.com

# --- LLM API keys ---
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx
LLM_MODEL=claude-sonnet-4-6

# --- Agent ---
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_RANDOM_HEX_48
TOOL_LEDGER_SIGNING_KEY=CHANGE_ME_RANDOM_HEX_64
TAVILY_API_KEY=tvly-xxxx

# --- Artifacts ---
AGENT_ARTIFACTS_DIR=/app/data/agent_artifacts

# --- App settings ---
APP_ENV=production
ENV=production
DEV_MODE=0
SESSION_TTL_DAYS=30
