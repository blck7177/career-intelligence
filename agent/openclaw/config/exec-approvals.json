{
  "version": 1,
  "defaults": {
    "security": "deny",
    "ask": "on-miss",
    "askFallback": "deny",
    "autoAllowSkills": false
  },
  "agents": {
    "career-search-agent": {
      "security": "allowlist",
      "ask": "on-miss",
      "allowlist": [
        {
          "id": "a1b2c3d4-0001-4000-8000-career000001",
