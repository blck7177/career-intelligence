        },
        {
          "id": "a1b2c3d4-0003-4000-8000-career000003",
          "pattern": "/usr/local/bin/python3",
          "argPattern": "^/app/tools/wrappers/agent_tools/career_write_manifest\\.py",
          "source": "allow-always"
        },
        {
          "id": "a1b2c3d4-0004-4000-8000-career000004",
