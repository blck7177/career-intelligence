{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost",
        "http://127.0.0.1",
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://localhost:18790",
        "http://127.0.0.1:18790",
        "http://localhost:80",
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": { "primary": "openai/gpt-5.4-mini" },
      "models": {
        "openai/gpt-5.4-mini": {
          "agentRuntime": { "id": "openclaw" }
        }
      },
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "career-search-agent",
        "workspace": "/openclaw/workspace/agents/career-search-agent",
        "skills": ["career-search-operator"]
      },
      {
        "id": "career-reflect-agent",
        "workspace": "/openclaw/workspace/agents/career-reflect-agent",
        "skills": ["career-reflect-operator"]
      },
      {
        "id": "career-research-agent",
        "workspace": "/openclaw/workspace/agents/career-research-agent",
        "skills": ["career-research-operator"]
      }
    ]
  },
  "skills": {
    "load": {
      "extraDirs": ["/app/agent/openclaw/skills"]
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "duckduckgo",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      }
    }
  }
}
