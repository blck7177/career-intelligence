{
  "gateway": {
    "mode": "local",
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "model": { "primary": "openai/gpt-5.4-mini" },
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "career-search-agent",
        "workspace": "/app/agent/openclaw/agents/career-search-agent",
        "skills": ["career-search-operator"]
      },
      {
        "id": "career-reflect-agent",
        "workspace": "/app/agent/openclaw/agents/career-reflect-agent",
        "skills": ["career-reflect-operator"]
      },
      {
        "id": "career-research-agent",
        "workspace": "/app/agent/openclaw/agents/career-research-agent",
        "skills": ["career-research-operator"]
      }
    ]
  },
  "skills": {
    "load": {
      "extraDirs": ["/app/agent/openclaw/skills"]
    }
  }
}
